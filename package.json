{
  "name": "collatr-edge",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun build --compile --minify --sourcemap --external=@serialport/bindings-cpp --outfile collatr-edge src/index.ts",
    "build:arm64": "bun build --compile --minify --sourcemap --target=bun-linux-arm64 --external=@serialport/bindings-cpp --outfile collatr-edge-arm64 src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/html": "^1.4.0",
    "@starfederation/datastar-sdk": "^1.0.0-RC.3",
    "elysia": "^1.4.25",
    "modbus-serial": "^8.0.23",
    "mqtt": "^5.15.0",
    "msgpackr": "^1.11.8",
    "node-opcua": "^2.163.1",
    "smol-toml": "^1.6.0",
    "sparkplug-payload": "^1.0.3",
    "zod": "^4.3.6"
  }
}
